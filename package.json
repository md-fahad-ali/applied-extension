{
  "name": "applied",
  "displayName": "applied",
  "version": "0.0.0",
  "author": "Md.Fahad Ali",
  "description": "",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "react",
    "vite",
    "create-chrome-ext"
  ],
  "engines": {
    "node": ">=14.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:puppeteer",
    "build:puppeteer": "rollup -c rollup.config.js",
    "build:all": "npm run build:puppeteer && npm run build",
    "preview": "vite preview",
    "fmt": "prettier --write '**/*.{tsx,ts,json,css,scss,md}'",
    "zip": "npm run build && node src/zip.js",
    "generate:pdf": "tsx generate-cv-pdf.ts"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.9.11",
    "jspdf": "^2.5.2",
    "libphonenumber-js": "^1.12.39",
    "pdfjs-dist": "^5.5.207",
    "puppeteer-core": "^24.38.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.26",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chrome": "^0.0.246",
    "@types/react": "^18.2.28",
    "@types/react-dom": "^18.2.13",
    "@vitejs/plugin-react": "^4.1.0",
    "gulp": "^5.0.0",
    "gulp-zip": "^6.0.0",
    "prettier": "^3.0.3",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.4.10"
  }
}